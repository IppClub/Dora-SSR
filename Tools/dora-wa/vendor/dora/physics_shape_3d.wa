import "runtime"

#wa:import dora physicsshape3d_type
func physicsshape3d_type() => i32

#wa:import dora physicsshape3d_is_built
func physicsshape3d_is_built(slf: i64) => i32

#wa:import dora physicsshape3d_add_child
func physicsshape3d_add_child(slf: i64, shape: i64, position: i64, euler_angles: i64) => i32

#wa:import dora physicsshape3d_build
func physicsshape3d_build(slf: i64) => i32

#wa:import dora physicsshape3d_with_box
func physicsshape3d_with_box(half_extent: i64) => i64

#wa:import dora physicsshape3d_with_sphere
func physicsshape3d_with_sphere(radius: f32) => i64

#wa:import dora physicsshape3d_with_capsule
func physicsshape3d_with_capsule(half_height: f32, radius: f32) => i64

#wa:import dora physicsshape3d_with_compound
func physicsshape3d_with_compound() => i64

#wa:import dora physicsshape3d_load_mesh_async
func physicsshape3d_load_mesh_async(filename: i64, func0: i32, stack0: i64)

#wa:import dora physicsshape3d_load_convex_hull_async
func physicsshape3d_load_convex_hull_async(filename: i64, func0: i32, stack0: i64)

type PhysicsShape3D :struct{ Object }

func PhysicsShape3DFrom(raw: i64) => *PhysicsShape3D {
	if raw == 0 {
		return nil
	}
	object := PhysicsShape3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	result := &object
	return result
}
func PhysicsShape3D.GetTypeId() => i32 {
	return physicsshape3d_type()
}
func ObjectAsPhysicsShape3D(object: Object) => *PhysicsShape3D {
	if object.GetTypeId() == physicsshape3d_type() {
		ObjectRetain(object.GetRaw())
		return PhysicsShape3DFrom(object.GetRaw())
	}
	return nil
}

/// Gets whether this shape can be used to create bodies.
func PhysicsShape3D.IsBuilt() => bool {
	return physicsshape3d_is_built(*this.raw) != 0
}

/// Adds a child to an unbuilt compound shape using local position and XYZ Euler angles in degrees.
func PhysicsShape3D.AddChild(shape: PhysicsShape3D, position: Vec3, euler_angles: Vec3) => bool {
	return physicsshape3d_add_child(*this.raw, shape.GetRaw(), position.GetRaw(), euler_angles.GetRaw()) != 0
}

/// Freezes a compound shape. A built shape cannot be modified.
func PhysicsShape3D.Build() => bool {
	return physicsshape3d_build(*this.raw) != 0
}

/// Creates a box shape using half extents.
func NewPhysicsShape3DWithBox(half_extent: Vec3) => PhysicsShape3D {
	raw := physicsshape3d_with_box(half_extent.GetRaw())
	object := PhysicsShape3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	return object
}

/// Creates a sphere shape.
func NewPhysicsShape3DWithSphere(radius: f32) => PhysicsShape3D {
	raw := physicsshape3d_with_sphere(radius)
	object := PhysicsShape3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	return object
}

/// Creates a capsule shape.
func NewPhysicsShape3DWithCapsule(half_height: f32, radius: f32) => PhysicsShape3D {
	raw := physicsshape3d_with_capsule(half_height, radius)
	object := PhysicsShape3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	return object
}

/// Creates an empty compound shape builder.
func NewPhysicsShape3DWithCompound() => PhysicsShape3D {
	raw := physicsshape3d_with_compound()
	object := PhysicsShape3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	return object
}

/// Loads and cooks a static triangle mesh shape through Content asynchronously.
func PhysicsShape3DLoadMeshAsync(filename: string, handler: func(shape: PhysicsShape3D)) {
	stack0 := NewCallStack()
	func_id0 := PushFunction(func() {
		shape_obj := stack0.PopObject()
		ObjectRetain(shape_obj.GetRaw())
		shape := *PhysicsShape3DFrom(shape_obj.GetRaw())
		handler(shape)
	})
	physicsshape3d_load_mesh_async(ToDoraString(filename), func_id0, *stack0.raw)
}

/// Loads model vertices through Content asynchronously and cooks a convex hull suitable for dynamic bodies.
func PhysicsShape3DLoadConvexHullAsync(filename: string, handler: func(shape: PhysicsShape3D)) {
	stack0 := NewCallStack()
	func_id0 := PushFunction(func() {
		shape_obj := stack0.PopObject()
		ObjectRetain(shape_obj.GetRaw())
		shape := *PhysicsShape3DFrom(shape_obj.GetRaw())
		handler(shape)
	})
	physicsshape3d_load_convex_hull_async(ToDoraString(filename), func_id0, *stack0.raw)
}
