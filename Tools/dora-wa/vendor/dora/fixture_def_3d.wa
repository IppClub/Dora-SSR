import "runtime"

#wa:import dora fixturedef3d_type
func fixturedef3d_type() => i32

#wa:import dora fixturedef3d_is_built
func fixturedef3d_is_built(slf: i64) => i32

#wa:import dora fixturedef3d_add_child
func fixturedef3d_add_child(slf: i64, shape: i64, position: i64, angles: i64) => i32

#wa:import dora fixturedef3d_build
func fixturedef3d_build(slf: i64) => i32

#wa:import dora fixturedef3d_with_box
func fixturedef3d_with_box(half_extent: i64) => i64

#wa:import dora fixturedef3d_with_sphere
func fixturedef3d_with_sphere(radius: f32) => i64

#wa:import dora fixturedef3d_with_capsule
func fixturedef3d_with_capsule(half_height: f32, radius: f32) => i64

#wa:import dora fixturedef3d_with_compound
func fixturedef3d_with_compound() => i64

#wa:import dora fixturedef3d_load_mesh_async
func fixturedef3d_load_mesh_async(filename: i64, func0: i32, stack0: i64)

#wa:import dora fixturedef3d_load_convex_hull_async
func fixturedef3d_load_convex_hull_async(filename: i64, func0: i32, stack0: i64)

type FixtureDef3D :struct{ Object }

func FixtureDef3DFrom(raw: i64) => *FixtureDef3D {
	if raw == 0 {
		return nil
	}
	object := FixtureDef3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	result := &object
	return result
}
func FixtureDef3D.GetTypeId() => i32 {
	return fixturedef3d_type()
}
func ObjectAsFixtureDef3D(object: Object) => *FixtureDef3D {
	if object.GetTypeId() == fixturedef3d_type() {
		ObjectRetain(object.GetRaw())
		return FixtureDef3DFrom(object.GetRaw())
	}
	return nil
}

/// Gets whether this shape can be used to create bodies.
func FixtureDef3D.IsBuilt() => bool {
	return fixturedef3d_is_built(*this.raw) != 0
}

/// Adds a child to an unbuilt compound shape using local position and XYZ Euler angles in degrees.
func FixtureDef3D.AddChild(shape: FixtureDef3D, position: Vec3, angles: Vec3) => bool {
	return fixturedef3d_add_child(*this.raw, shape.GetRaw(), position.GetRaw(), angles.GetRaw()) != 0
}

/// Freezes a compound shape. A built shape cannot be modified.
func FixtureDef3D.Build() => bool {
	return fixturedef3d_build(*this.raw) != 0
}

/// Creates a box shape using half extents.
func NewFixtureDef3DWithBox(half_extent: Vec3) => FixtureDef3D {
	raw := fixturedef3d_with_box(half_extent.GetRaw())
	object := FixtureDef3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	return object
}

/// Creates a sphere shape.
func NewFixtureDef3DWithSphere(radius: f32) => FixtureDef3D {
	raw := fixturedef3d_with_sphere(radius)
	object := FixtureDef3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	return object
}

/// Creates a capsule shape.
func NewFixtureDef3DWithCapsule(half_height: f32, radius: f32) => FixtureDef3D {
	raw := fixturedef3d_with_capsule(half_height, radius)
	object := FixtureDef3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	return object
}

/// Creates an empty compound shape builder.
func NewFixtureDef3DWithCompound() => FixtureDef3D {
	raw := fixturedef3d_with_compound()
	object := FixtureDef3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	return object
}

/// Loads and cooks a static triangle mesh shape through Content asynchronously.
func FixtureDef3DLoadMeshAsync(filename: string, handler: func(shape: FixtureDef3D)) {
	stack0 := NewCallStack()
	func_id0 := PushFunction(func() {
		shape_obj := stack0.PopObject()
		ObjectRetain(shape_obj.GetRaw())
		shape := *FixtureDef3DFrom(shape_obj.GetRaw())
		handler(shape)
	})
	fixturedef3d_load_mesh_async(ToDoraString(filename), func_id0, *stack0.raw)
}

/// Loads model vertices through Content asynchronously and cooks a convex hull suitable for dynamic bodies.
func FixtureDef3DLoadConvexHullAsync(filename: string, handler: func(shape: FixtureDef3D)) {
	stack0 := NewCallStack()
	func_id0 := PushFunction(func() {
		shape_obj := stack0.PopObject()
		ObjectRetain(shape_obj.GetRaw())
		shape := *FixtureDef3DFrom(shape_obj.GetRaw())
		handler(shape)
	})
	fixturedef3d_load_convex_hull_async(ToDoraString(filename), func_id0, *stack0.raw)
}
