func material3d_clear_occlusion_texture(slf: i64)

type Material3D :struct{ Object }

func Material3DFrom(raw: i64) => *Material3D {
	if raw == 0 {
		return nil
	}
	object := Material3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	result := &object
	return result
}
func Material3D.GetTypeId() => i32 {
	return material3d_type()
}
func ObjectAsMaterial3D(object: Object) => *Material3D {
	if object.GetTypeId() == material3d_type() {
		ObjectRetain(object.GetRaw())
		return Material3DFrom(object.GetRaw())
	}
	return nil
}

/// Sets the base color tint.
func Material3D.SetBaseColor(val: Color) {
	material3d_set_base_color(*this.raw, val.ToARGB())
}

/// Gets the base color tint.
func Material3D.GetBaseColor() => Color {
	return NewColor(material3d_get_base_color(*this.raw))
}

/// Sets the emissive color factor.
func Material3D.SetEmissive(val: Color3) {
	material3d_set_emissive(*this.raw, val.ToRGB())
}

/// Gets the emissive color factor.
func Material3D.GetEmissive() => Color3 {
	return NewColor3(material3d_get_emissive(*this.raw))
}

/// Sets the metallic factor.
func Material3D.SetMetallic(val: f32) {
	material3d_set_metallic(*this.raw, val)
}

/// Gets the metallic factor.
func Material3D.GetMetallic() => f32 {
	return material3d_get_metallic(*this.raw)
}

/// Sets the roughness factor.
func Material3D.SetRoughness(val: f32) {
	material3d_set_roughness(*this.raw, val)
}

/// Gets the roughness factor.
func Material3D.GetRoughness() => f32 {
	return material3d_get_roughness(*this.raw)
}

/// Sets the alpha rendering mode.
func Material3D.SetAlphaMode(val: MaterialAlphaMode3D) {
	material3d_set_alpha_mode(*this.raw, val.ToValue())
}

/// Gets the alpha rendering mode.
func Material3D.GetAlphaMode() => MaterialAlphaMode3D {
	return MaterialAlphaMode3D{value: material3d_get_alpha_mode(*this.raw)}
}

/// Sets the alpha mask cutoff.
func Material3D.SetAlphaCutoff(val: f32) {
	material3d_set_alpha_cutoff(*this.raw, val)
}

/// Gets the alpha mask cutoff.
func Material3D.GetAlphaCutoff() => f32 {
	return material3d_get_alpha_cutoff(*this.raw)
}

/// Replaces or clears the base color texture.
func Material3D.SetBaseColorTexture(texture: Texture2D) {
	material3d_set_base_color_texture(*this.raw, texture.GetRaw())
}

/// Clears the base color texture override.
func Material3D.ClearBaseColorTexture() {
	material3d_clear_base_color_texture(*this.raw)
}

/// Replaces or clears the metallic-roughness texture.
func Material3D.SetMetallicRoughnessTexture(texture: Texture2D) {
	material3d_set_metallic_roughness_texture(*this.raw, texture.GetRaw())
}

/// Clears the metallic-roughness texture override.
func Material3D.ClearMetallicRoughnessTexture() {
	material3d_clear_metallic_roughness_texture(*this.raw)
}

/// Replaces or clears the normal texture.
func Material3D.SetNormalTexture(texture: Texture2D) {
	material3d_set_normal_texture(*this.raw, texture.GetRaw())
}

/// Clears the normal texture override.
func Material3D.ClearNormalTexture() {
	material3d_clear_normal_texture(*this.raw)
}

/// Replaces or clears the emissive texture.
func Material3D.SetEmissiveTexture(texture: Texture2D) {
	material3d_set_emissive_texture(*this.raw, texture.GetRaw())
}

/// Clears the emissive texture override.
func Material3D.ClearEmissiveTexture() {
	material3d_clear_emissive_texture(*this.raw)
}

/// Replaces or clears the occlusion texture.
func Material3D.SetOcclusionTexture(texture: Texture2D) {
	material3d_set_occlusion_texture(*this.raw, texture.GetRaw())
}

/// Clears the occlusion texture override.
func Material3D.ClearOcclusionTexture() {
	material3d_clear_occlusion_texture(*this.raw)
}
