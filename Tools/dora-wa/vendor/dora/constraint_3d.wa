import "runtime"

#wa:import dora constraint3d_type
func constraint3d_type() => i32

#wa:import dora constraint3d_get_world
func constraint3d_get_world(slf: i64) => i64

#wa:import dora constraint3d_get_first_body
func constraint3d_get_first_body(slf: i64) => i64

#wa:import dora constraint3d_get_second_body
func constraint3d_get_second_body(slf: i64) => i64

#wa:import dora constraint3d_destroy
func constraint3d_destroy(slf: i64)

type Constraint3D :struct{ Object }

func Constraint3DFrom(raw: i64) => *Constraint3D {
	if raw == 0 {
		return nil
	}
	object := Constraint3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	result := &object
	return result
}
func Constraint3D.GetTypeId() => i32 {
	return constraint3d_type()
}
func ObjectAsConstraint3D(object: Object) => *Constraint3D {
	if object.GetTypeId() == constraint3d_type() {
		ObjectRetain(object.GetRaw())
		return Constraint3DFrom(object.GetRaw())
	}
	return nil
}

/// Gets the physics world that owns this constraint.
func Constraint3D.GetWorld() => *PhysicsWorld3D {
	ptr_ := constraint3d_get_world(*this.raw)
	if ptr_ == 0 {
		return nil
	}
	obj_ := *PhysicsWorld3DFrom(ptr_)
	return &obj_
}

/// Gets the first constrained body.
func Constraint3D.GetFirstBody() => *Body3D {
	ptr_ := constraint3d_get_first_body(*this.raw)
	if ptr_ == 0 {
		return nil
	}
	obj_ := *Body3DFrom(ptr_)
	return &obj_
}

/// Gets the second constrained body.
func Constraint3D.GetSecondBody() => *Body3D {
	ptr_ := constraint3d_get_second_body(*this.raw)
	if ptr_ == 0 {
		return nil
	}
	obj_ := *Body3DFrom(ptr_)
	return &obj_
}

/// Removes this constraint from its physics world.
func Constraint3D.Destroy() {
	constraint3d_destroy(*this.raw)
}
