type RenderStats3D :struct{ raw: *i64 }

func RenderStats3D.GetRaw() => i64 {
	return *this.raw
}
func render_stats_3d_finalizer(ptr: u32) {
	renderstats3d_release(GetPtr(ptr))
}
func RenderStats3DFrom(raw: i64) => *RenderStats3D {
	if raw == 0 {
		return nil
	}
	item := RenderStats3D{}
	item.raw = &raw
	runtime.SetFinalizer(item.raw, render_stats_3d_finalizer)
	result := &item
	return result
}
func RenderStats3D.GetSceneNodes() => i32 {
	return renderstats3d_get_scene_nodes(*this.raw)
}
func RenderStats3D.GetVisibleVisuals() => i32 {
	return renderstats3d_get_visible_visuals(*this.raw)
