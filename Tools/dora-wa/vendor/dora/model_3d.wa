import "runtime"

#wa:import dora model3d_type
func model3d_type() => i32

#wa:import dora model3d_set_speed
func model3d_set_speed(slf: i64, val: f32)

#wa:import dora model3d_get_speed
func model3d_get_speed(slf: i64) => f32

#wa:import dora model3d_get_duration
func model3d_get_duration(slf: i64) => f32

#wa:import dora model3d_get_elapsed
func model3d_get_elapsed(slf: i64) => f32

#wa:import dora model3d_is_playing
func model3d_is_playing(slf: i64) => i32

#wa:import dora model3d_is_paused
func model3d_is_paused(slf: i64) => i32

#wa:import dora model3d_play
func model3d_play(slf: i64, name: i64, looped: i32) => f32

#wa:import dora model3d_stop
func model3d_stop(slf: i64)

#wa:import dora model3d_pause
func model3d_pause(slf: i64)

#wa:import dora model3d_resume
func model3d_resume(slf: i64)

#wa:import dora model3d_new
func model3d_new(path: i64) => i64

type Model3D :struct{ Node3D }

func Model3DFrom(raw: i64) => *Model3D {
	if raw == 0 {
		return nil
	}
	object := Model3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	result := &object
	return result
}
func Model3D.GetTypeId() => i32 {
	return model3d_type()
}
func ObjectAsModel3D(object: Object) => *Model3D {
	if object.GetTypeId() == model3d_type() {
		ObjectRetain(object.GetRaw())
		return Model3DFrom(object.GetRaw())
	}
	return nil
}

/// Sets the animation playback speed.
func Model3D.SetSpeed(val: f32) {
	model3d_set_speed(*this.raw, val)
}

/// Gets the animation playback speed.
func Model3D.GetSpeed() => f32 {
	return model3d_get_speed(*this.raw)
}

/// Gets the current animation duration.
func Model3D.GetDuration() => f32 {
	return model3d_get_duration(*this.raw)
}

/// Gets the elapsed playback time.
func Model3D.GetElapsed() => f32 {
	return model3d_get_elapsed(*this.raw)
}

/// Gets whether an animation is playing.
func Model3D.IsPlaying() => bool {
	return model3d_is_playing(*this.raw) != 0
}

/// Gets whether animation playback is paused.
func Model3D.IsPaused() => bool {
	return model3d_is_paused(*this.raw) != 0
}

/// Plays an animation by name.
func Model3D.Play(name: string, looped: bool) => f32 {
	return model3d_play(*this.raw, ToDoraString(name), ToDoraBool(looped))
}

/// Stops animation playback.
func Model3D.Stop() {
	model3d_stop(*this.raw)
}

/// Pauses animation playback.
func Model3D.Pause() {
	model3d_pause(*this.raw)
}

/// Resumes animation playback.
func Model3D.Resume() {
	model3d_resume(*this.raw)
}

/// Creates a model from a glTF/GLB file.
func NewModel3D(path: string) => *Model3D {
	raw := model3d_new(ToDoraString(path))
	if raw == 0 {
		return nil
	}
	object := Model3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	return &object
}
