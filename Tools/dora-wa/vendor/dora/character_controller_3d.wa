import "runtime"

#wa:import dora charactercontroller3d_type
func charactercontroller3d_type() => i32

#wa:import dora charactercontroller3d_get_node
func charactercontroller3d_get_node(slf: i64) => i64

#wa:import dora charactercontroller3d_get_world
func charactercontroller3d_get_world(slf: i64) => i64

#wa:import dora charactercontroller3d_set_desired_velocity
func charactercontroller3d_set_desired_velocity(slf: i64, val: i64)

#wa:import dora charactercontroller3d_get_desired_velocity
func charactercontroller3d_get_desired_velocity(slf: i64) => i64

#wa:import dora charactercontroller3d_get_velocity
func charactercontroller3d_get_velocity(slf: i64) => i64

#wa:import dora charactercontroller3d_get_ground_normal
func charactercontroller3d_get_ground_normal(slf: i64) => i64

#wa:import dora charactercontroller3d_is_grounded
func charactercontroller3d_is_grounded(slf: i64) => i32

#wa:import dora charactercontroller3d_set_collision_layer
func charactercontroller3d_set_collision_layer(slf: i64, val: i32)

#wa:import dora charactercontroller3d_get_collision_layer
func charactercontroller3d_get_collision_layer(slf: i64) => i32

#wa:import dora charactercontroller3d_set_collision_mask
func charactercontroller3d_set_collision_mask(slf: i64, val: i32)

#wa:import dora charactercontroller3d_get_collision_mask
func charactercontroller3d_get_collision_mask(slf: i64) => i32

#wa:import dora charactercontroller3d_jump
func charactercontroller3d_jump(slf: i64, speed: f32)

#wa:import dora charactercontroller3d_destroy
func charactercontroller3d_destroy(slf: i64)

type CharacterController3D :struct{ Object }

func CharacterController3DFrom(raw: i64) => *CharacterController3D {
	if raw == 0 {
		return nil
	}
	object := CharacterController3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	result := &object
	return result
}
func CharacterController3D.GetTypeId() => i32 {
	return charactercontroller3d_type()
}
func ObjectAsCharacterController3D(object: Object) => *CharacterController3D {
	if object.GetTypeId() == charactercontroller3d_type() {
		ObjectRetain(object.GetRaw())
		return CharacterController3DFrom(object.GetRaw())
	}
	return nil
}

/// Gets the Node3D synchronized with this character.
func CharacterController3D.GetNode() => *Node3D {
	ptr_ := charactercontroller3d_get_node(*this.raw)
	if ptr_ == 0 {
		return nil
	}
	obj_ := *Node3DFrom(ptr_)
	return &obj_
}

/// Gets the physics world that owns this character.
func CharacterController3D.GetWorld() => *PhysicsWorld3D {
	ptr_ := charactercontroller3d_get_world(*this.raw)
	if ptr_ == 0 {
		return nil
	}
	obj_ := *PhysicsWorld3DFrom(ptr_)
	return &obj_
}

/// Sets the desired horizontal movement velocity.
func CharacterController3D.SetDesiredVelocity(val: Vec3) {
	charactercontroller3d_set_desired_velocity(*this.raw, val.GetRaw())
}

/// Gets the desired horizontal movement velocity.
func CharacterController3D.GetDesiredVelocity() => Vec3 {
	return *Vec3From(charactercontroller3d_get_desired_velocity(*this.raw))
}

/// Gets the current world-space velocity including gravity and jumping.
func CharacterController3D.GetVelocity() => Vec3 {
	return *Vec3From(charactercontroller3d_get_velocity(*this.raw))
}

/// Gets the current supporting surface normal.
func CharacterController3D.GetGroundNormal() => Vec3 {
	return *Vec3From(charactercontroller3d_get_ground_normal(*this.raw))
}

/// Gets whether the character is standing on walkable ground.
func CharacterController3D.IsGrounded() => bool {
	return charactercontroller3d_is_grounded(*this.raw) != 0
}

/// Sets the collision layer in the range 0 through 31.
func CharacterController3D.SetCollisionLayer(val: i32) {
	charactercontroller3d_set_collision_layer(*this.raw, val)
}

/// Gets the collision layer in the range 0 through 31.
func CharacterController3D.GetCollisionLayer() => i32 {
	return charactercontroller3d_get_collision_layer(*this.raw)
}

/// Sets the bit mask of collision layers accepted by this character.
func CharacterController3D.SetCollisionMask(val: i32) {
	charactercontroller3d_set_collision_mask(*this.raw, val)
}

/// Gets the bit mask of collision layers accepted by this character.
func CharacterController3D.GetCollisionMask() => i32 {
	return charactercontroller3d_get_collision_mask(*this.raw)
}

/// Requests a jump with the given upward speed.
func CharacterController3D.Jump(speed: f32) {
	charactercontroller3d_jump(*this.raw, speed)
}

/// Removes this character from its physics world.
func CharacterController3D.Destroy() {
	charactercontroller3d_destroy(*this.raw)
}
