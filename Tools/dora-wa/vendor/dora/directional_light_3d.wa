import "runtime"

#wa:import dora directionallight3d_type
func directionallight3d_type() => i32

#wa:import dora directionallight3d_set_color
func directionallight3d_set_color(slf: i64, val: i32)

#wa:import dora directionallight3d_get_color
func directionallight3d_get_color(slf: i64) => i32

#wa:import dora directionallight3d_set_intensity
func directionallight3d_set_intensity(slf: i64, val: f32)

#wa:import dora directionallight3d_get_intensity
func directionallight3d_get_intensity(slf: i64) => f32

#wa:import dora directionallight3d_new
func directionallight3d_new() => i64

type DirectionalLight3D :struct{ Node3D }

func DirectionalLight3DFrom(raw: i64) => *DirectionalLight3D {
	if raw == 0 {
		return nil
	}
	object := DirectionalLight3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	result := &object
	return result
}
func DirectionalLight3D.GetTypeId() => i32 {
	return directionallight3d_type()
}
func ObjectAsDirectionalLight3D(object: Object) => *DirectionalLight3D {
	if object.GetTypeId() == directionallight3d_type() {
		ObjectRetain(object.GetRaw())
		return DirectionalLight3DFrom(object.GetRaw())
	}
	return nil
}

/// Sets the light color in sRGB space.
func DirectionalLight3D.SetColor(val: Color3) {
	directionallight3d_set_color(*this.raw, val.ToRGB())
}

/// Gets the light color in sRGB space.
func DirectionalLight3D.GetColor() => Color3 {
	return NewColor3(directionallight3d_get_color(*this.raw))
}

/// Sets the light intensity.
func DirectionalLight3D.SetIntensity(val: f32) {
	directionallight3d_set_intensity(*this.raw, val)
}

/// Gets the light intensity.
func DirectionalLight3D.GetIntensity() => f32 {
	return directionallight3d_get_intensity(*this.raw)
}

/// Creates a directional light.
func NewDirectionalLight3D() => DirectionalLight3D {
	raw := directionallight3d_new()
	object := DirectionalLight3D{}
	object.raw = &raw
	runtime.SetFinalizer(object.raw, ObjectFinalizer)
	return object
}
